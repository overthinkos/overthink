{
  "includeCoAuthoredBy": false,
  "worktree": {
    "bgIsolation": "none"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "auto",
  "permissions": {
    "allow": [
      "Bash(charly eval run:*)",
      "Bash(charly eval live:*)",
      "Bash(charly eval box:*)",
      "Bash(charly status:*)"
    ]
  },
  "enabledPlugins": {
    "ov-core@ov-plugins": true,
    "ov-build@ov-plugins": true,
    "ov-eval@ov-plugins": true,
    "ov-automation@ov-plugins": true,
    "ov-image@ov-plugins": true,
    "ov-vm@ov-plugins": true,
    "ov-kubernetes@ov-plugins": true,
    "ov-local@ov-plugins": true,
    "ov-pod@ov-plugins": true,
    "ov-internals@ov-plugins": true,
    "ov-distros@ov-plugins": true,
    "ov-languages@ov-plugins": true,
    "ov-infrastructure@ov-plugins": true,
    "ov-tools@ov-plugins": true,
    "ov-jupyter@ov-plugins": true,
    "ov-coder@ov-plugins": true,
    "ov-selkies@ov-plugins": true,
    "ov-openclaw@ov-plugins": true,
    "ov-versa@ov-plugins": true,
    "ov-ollama@ov-plugins": true,
    "ov-openwebui@ov-plugins": true,
    "ov-comfyui@ov-plugins": true,
    "ov-immich@ov-plugins": true,
    "ov-hermes@ov-plugins": true,
    "ov-filebrowser@ov-plugins": true,
    "claude-md-management@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ov-plugins": {
      "source": {
        "source": "directory",
        "path": "./plugins"
      }
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/runtime-verification-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/end-of-turn-challenge.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-gate.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-gate.sh"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/team-coordination-reminder.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/team-coordination-reminder.sh"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/team-coordination-reminder.sh"
          }
        ]
      }
    ]
  }
}
