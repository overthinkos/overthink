{
  "includeCoAuthoredBy": false,
  "enabledPlugins": {
    "ov-core@ov-plugins": true,
    "ov-build@ov-plugins": true,
    "ov-advanced@ov-plugins": true,
    "ov-foundation@ov-plugins": true,
    "ov-dev@ov-plugins": true,
    "ov-vms@ov-plugins": true,
    "ov-jupyter@ov-plugins": true,
    "ov-coder@ov-plugins": true,
    "ov-selkies@ov-plugins": true,
    "ov-openclaw@ov-plugins": true,
    "ov-ollama@ov-plugins": true,
    "ov-openwebui@ov-plugins": true,
    "ov-comfyui@ov-plugins": true,
    "ov-immich@ov-plugins": true,
    "ov-hermes@ov-plugins": true,
    "ov-filebrowser@ov-plugins": true,
    "claude-md-management@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ov-plugins": {
      "source": {
        "source": "directory",
        "path": "./plugins"
      }
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/runtime-verification-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/end-of-turn-challenge.sh"
          }
        ]
      }
    ]
  }
}
