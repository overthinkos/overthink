# .env.example — Copy to .env and fill in values. .env is gitignored.
#
# Loaded by ov CLI (startup) and direnv (shell entry).
# Container commands (start/shell/enable) also inject these into containers.

# ── Application secrets ──────────────────────────
# GMAIL_USER=
# GMAIL_PASSWORD=

# ── ov CLI configuration ────────────────────────
# OV_BUILD_ENGINE=podman
# OV_RUN_ENGINE=podman
# OV_RUN_MODE=quadlet
# OV_AUTO_ENABLE=true
# OV_BIND_ADDRESS=127.0.0.1
