# .env.example — Reference for variables stored in .secrets (GPG-encrypted).
#
# Secrets are stored in .secrets (GPG-encrypted, safe to sync/commit).
# direnv decrypts .secrets in memory via charly secrets gpg env — no plaintext on disk.
#
# To create or update .secrets:
#   charly secrets gpg encrypt -r <KEY_ID> -i .env -o .secrets
#   charly secrets gpg set KEY VALUE         # Add/update individual keys
#   charly secrets gpg edit                  # Edit in $EDITOR
#   direnv allow
#
# Prerequisites: gpg-agent running + passphrase cached. See gpg-agent-setup.

# ── Application secrets ──────────────────────────
# GMAIL_USER=
# GMAIL_PASSWORD=

# ── charly CLI configuration ────────────────────────
# CHARLY_BUILD_ENGINE=podman
# CHARLY_RUN_ENGINE=podman
# CHARLY_RUN_MODE=quadlet
# CHARLY_AUTO_ENABLE=true
# CHARLY_BIND_ADDRESS=127.0.0.1
# CHARLY_FORWARD_GPG_AGENT=true
# CHARLY_FORWARD_SSH_AGENT=true
