# .env.example — Reference for variables stored in .secrets (GPG-encrypted).
#
# Secrets are stored in .secrets (GPG-encrypted, safe to sync/commit).
# direnv decrypts .secrets in memory via ov secrets gpg env — no plaintext on disk.
#
# To create or update .secrets:
#   ov secrets gpg encrypt -r <KEY_ID> -i .env -o .secrets
#   ov secrets gpg set KEY VALUE         # Add/update individual keys
#   ov secrets gpg edit                  # Edit in $EDITOR
#   direnv allow
#
# Prerequisites: gpg-agent running + passphrase cached. See gpg-agent-setup.

# ── Application secrets ──────────────────────────
# GMAIL_USER=
# GMAIL_PASSWORD=

# ── ov CLI configuration ────────────────────────
# OV_BUILD_ENGINE=podman
# OV_RUN_ENGINE=podman
# OV_RUN_MODE=quadlet
# OV_AUTO_ENABLE=true
# OV_BIND_ADDRESS=127.0.0.1
# OV_FORWARD_GPG_AGENT=true
# OV_FORWARD_SSH_AGENT=true
