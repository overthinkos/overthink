# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Built external-plugin provider binaries (candy/plugin-<name>/plugin-<name>) — the host
# go-builds these on demand from each plugin candy's module; the binary is an artifact,
# never committed (the binary name matches its dir name).
candy/plugin-*/plugin-*

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file — COMMITTED (not ignored): go.work is a generated artifact
# (pluginsgen, from charly.yml compiled_plugins:) that maps the charly module + every
# compiled-in plugin candy, so `go build ./charly` / `go test ./...` resolve the candy
# imports in charly/plugins_generated.go WITHOUT first running `task build:charly`.
# go.work.sum is its checksum lock (committed for reproducible/offline builds). The
# reproducibility gate is TestPluginsGenReproducible.

# env files and GPG-encrypted secrets
.env
.secrets

# Migration rollback backups (`charly migrate` writes <file>.bak.<unix-ts>
# before rewriting a config; per-run, per-machine — not version-controlled)
*.bak
*.bak.*

# Editor/IDE
# .idea/
# .vscode/

# Claude Code local settings, memory, and ephemeral session state
# (synced via Syncthing, not git)
.claude/settings.local.json
.claude/memory/
.claude/plans/
.claude/scheduled_tasks.lock

# Machine-specific deploy overrides
deploy.local.yml

# OpenCharly build artifacts
.build/
bin/
charly/charly
output/
dist/

# Build-context ignore files — generated by `charly box generate` from
# defaults.context_ignore (baseline + project excludes). Both engines covered:
# podman reads .containerignore, docker reads .dockerignore.
.containerignore
.dockerignore

# Legacy `charly benchmark` cache (pre-2026-04).
.benchmark/

# `charly check` artifacts under <project>/.check/<recipe>/. Broadly
# gitignored — same pattern as .claude/memory/ + .claude/plans/: lives
# IN the project tree so Syncthing-style file replication carries the
# durable result files + NOTES.md memory across the user's machines,
# but stays OUT of git history (per-machine + per-run state, not
# version-controlled source).
.check/

# Syncthing conflict copies — created when the Syncthing-synced project tree
# diverges on two machines (e.g. a file is edited while a stale copy replicates
# in). Per-machine, ephemeral, resolved by hand — never version-controlled.
*.sync-conflict-*

# Screenshots and temporary images
*.png
*.jpg
*.jpeg

# RPM packages
*.rpm

# KeePass credential databases (local, not committed)
*.kdbx

# Containerfile regression snapshot (ephemeral; used during the charly bundle
# refactor to verify byte-identical output after IR lift)
/.regression-snapshot/
/.regression-snapshot-checksums.txt

# ML model weights and training state (reproducible from notebooks)
*.safetensors
optimizer.pt
scheduler.pt
rng_state.pth
scaler.pt
pytorch_model*.bin
*.gguf
*.ckpt
*.onnx
*.h5
