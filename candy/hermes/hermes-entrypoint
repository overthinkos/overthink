#!/bin/bash
# Hermes Agent entrypoint — initializes data volume and starts the agent.
# Based on upstream docker/entrypoint.sh.
set -e

HERMES_HOME="${HERMES_HOME:-/opt/data}"
HERMES_SRC="$HOME/hermes-agent"
MARKER="# ov:auto-configured"

# Create data directory structure
mkdir -p "$HERMES_HOME"/{cron,sessions,logs,hooks,memories,skills}

# Bootstrap config files if not present
[ -f "$HERMES_HOME/.env" ] || cp "$HERMES_SRC/.env.example" "$HERMES_HOME/.env"
[ -f "$HERMES_HOME/config.yaml" ] || cp "$HERMES_SRC/cli-config.yaml.example" "$HERMES_HOME/config.yaml"
[ -f "$HERMES_HOME/SOUL.md" ] || cp "$HERMES_SRC/docker/SOUL.md" "$HERMES_HOME/SOUL.md"

# One-time auto-configuration (LLM providers + MCP servers)
# Runs only on first start. To reconfigure: delete config.yaml and restart.
if ! grep -q "$MARKER" "$HERMES_HOME/config.yaml" 2>/dev/null; then
    python - "$HERMES_HOME/config.yaml" \
        "${OLLAMA_API_KEY:-}" \
        "${OPENROUTER_API_KEY:-}" \
        "${OLLAMA_HOST:-}" \
        "${HERMES_MODEL:-}" \
        "${OV_MCP_SERVERS:-}" \
        "${BROWSER_CDP_URL:-}" <<'PYEOF'
import sys, json, yaml, os

config_path = sys.argv[1]
ollama_key = sys.argv[2] or None
openrouter_key = sys.argv[3] or None
ollama_host = sys.argv[4] or None
model_override = sys.argv[5] or None
mcp_json = sys.argv[6] or None
cdp_url = sys.argv[7] or None

with open(config_path) as f:
    config = yaml.safe_load(f) or {}

config.setdefault('model', {})
aux = config.setdefault('auxiliary', {})
providers = config.setdefault('custom_providers', [])
configured = []

# --- LLM providers: register all available ---

if ollama_key:
    providers[:] = [p for p in providers if p.get('name') != 'ollama-cloud']
    providers.append({
        'name': 'ollama-cloud',
        'base_url': 'https://ollama.com/v1',
        'api_key': ollama_key,
    })
    configured.append('ollama-cloud')

if openrouter_key:
    configured.append('openrouter')

if ollama_host:
    base_url = ollama_host.rstrip('/') + '/v1'
    providers[:] = [p for p in providers if p.get('name') != 'ollama-local']
    providers.append({
        'name': 'ollama-local',
        'base_url': base_url,
        'api_key': 'ollama',
    })
    configured.append('ollama-local')

# --- LLM default model (priority: OLLAMA_HOST > OLLAMA_API_KEY > OPENROUTER_API_KEY) ---

if ollama_host:
    base_url = ollama_host.rstrip('/') + '/v1'
    config['model']['default'] = model_override or 'qwen2.5-coder:32b'
    config['model']['provider'] = 'custom'
    config['model']['base_url'] = base_url
    config['model']['context_length'] = 32768
    for task in ('compression', 'web_extract', 'vision'):
        aux.setdefault(task, {})
        aux[task]['provider'] = 'custom'
        aux[task]['base_url'] = base_url
        aux[task]['api_key'] = 'ollama'
elif ollama_key:
    config['model']['default'] = model_override or 'kimi-k2.5:cloud'
    config['model']['provider'] = 'custom'
    config['model']['base_url'] = 'https://ollama.com/v1'
    config['model']['context_length'] = 131072
    for task in ('compression', 'web_extract', 'vision'):
        aux.setdefault(task, {})
        aux[task]['provider'] = 'custom'
        aux[task]['base_url'] = 'https://ollama.com/v1'
        aux[task]['api_key'] = ollama_key
elif openrouter_key:
    config['model']['default'] = model_override or 'qwen/qwen3.6-plus:free'
    config['model']['provider'] = 'openrouter'
    config['model'].pop('base_url', None)
    config['model'].pop('context_length', None)
    for task in ('compression', 'web_extract', 'vision'):
        aux.setdefault(task, {})
        aux[task]['provider'] = 'openrouter'
        aux[task].pop('base_url', None)
        aux[task].pop('api_key', None)

# --- MCP servers ---

if mcp_json:
    try:
        servers = json.loads(mcp_json)
        if servers:
            mcp = config.setdefault('mcp_servers', {})
            for srv in servers:
                mcp[srv['name']] = {'url': srv['url']}
            configured.append(f"mcp({len(servers)})")
    except json.JSONDecodeError:
        print(f"hermes-entrypoint: warning: could not parse OV_MCP_SERVERS", file=sys.stderr)

# --- Browser (shared desktop Chrome via CDP) ---

if cdp_url:
    browser = config.setdefault('browser', {})
    browser['inactivity_timeout'] = 0  # Don't disconnect from shared browser
    configured.append('browser-cdp')

# --- Write config ---

with open(config_path, 'w') as f:
    f.write(f"# {os.path.basename(config_path)} — auto-generated by ov hermes-entrypoint\n")
    f.write("# To reconfigure: delete this file and restart the service.\n")
    yaml.dump(config, f, default_flow_style=False, sort_keys=False)
    f.write('# ov:auto-configured\n')

print('hermes-entrypoint: configured: ' + ', '.join(configured))
PYEOF
    # Log which default was selected
    if [ -n "$OLLAMA_HOST" ]; then
        echo "hermes-entrypoint: default=local Ollama at $OLLAMA_HOST (model=${HERMES_MODEL:-qwen2.5-coder:32b})"
    elif [ -n "$OLLAMA_API_KEY" ]; then
        echo "hermes-entrypoint: default=Ollama Cloud (model=${HERMES_MODEL:-kimi-k2.5:cloud})"
    elif [ -n "$OPENROUTER_API_KEY" ]; then
        echo "hermes-entrypoint: default=OpenRouter (model=${HERMES_MODEL:-qwen/qwen3.6-plus:free})"
    fi
else
    echo "hermes-entrypoint: config.yaml already configured (skipping)"
fi

# Log browser CDP connection (every start, not guarded by sentinel)
if [ -n "${BROWSER_CDP_URL:-}" ]; then
    echo "hermes-entrypoint: browser-cdp=$BROWSER_CDP_URL"
fi

# Sync API keys to hermes .env (every start — handles key rotation)
for VAR in OLLAMA_API_KEY OPENROUTER_API_KEY; do
    VAL=$(eval echo "\${$VAR:-}")
    [ -z "$VAL" ] && continue
    if ! grep -q "^${VAR}=" "$HERMES_HOME/.env" 2>/dev/null; then
        echo "${VAR}=${VAL}" >> "$HERMES_HOME/.env"
    else
        sed -i "s|^${VAR}=.*|${VAR}=${VAL}|" "$HERMES_HOME/.env"
    fi
done

# Sync bundled skills
if [ -d "$HERMES_SRC/skills" ]; then
    python "$HERMES_SRC/tools/skills_sync.py" 2>/dev/null || true
fi

exec hermes "$@"
