#!/bin/bash
set -euo pipefail

EMULATOR_NAME="${EMULATOR_NAME:-ov_avd_14}"
EMULATOR_API_LEVEL="${EMULATOR_API_LEVEL:-34}"
EMULATOR_DEVICE="${EMULATOR_DEVICE:-pixel_6}"
EMULATOR_IMG_TYPE="${EMULATOR_IMG_TYPE:-google_apis}"
EMULATOR_SYS_IMG="${EMULATOR_SYS_IMG:-x86_64}"
# Boot-speed tuning: more guest RAM + vCPUs makes the cold boot noticeably
# faster on a multi-core host. Named env (not magic numbers) so a deploy can
# size them down on constrained hosts.
EMULATOR_MEMORY="${EMULATOR_MEMORY:-3072}"
EMULATOR_CORES="${EMULATOR_CORES:-4}"
ANDROID_HOME="${ANDROID_HOME:-/opt/android-sdk}"
ANDROID_AVD_HOME="${ANDROID_AVD_HOME:-${HOME}/.android/avd}"
export ANDROID_HOME ANDROID_AVD_HOME

mkdir -p "${ANDROID_AVD_HOME}"

AVD_CONFIG="${ANDROID_AVD_HOME}/${EMULATOR_NAME}.avd/config.ini"
if [ ! -f "${AVD_CONFIG}" ]; then
  echo "[start-emulator] Creating AVD ${EMULATOR_NAME} (API ${EMULATOR_API_LEVEL}, device ${EMULATOR_DEVICE})..." >&2
  echo "no" | "${ANDROID_HOME}/cmdline-tools/latest/bin/avdmanager" create avd \
    --name "${EMULATOR_NAME}" \
    --package "system-images;android-${EMULATOR_API_LEVEL};${EMULATOR_IMG_TYPE};${EMULATOR_SYS_IMG}" \
    --device "${EMULATOR_DEVICE}" \
    --force
fi

# Pick acceleration mode at runtime: probe KVM via KVM_GET_API_VERSION
# ioctl (the only way to know for sure — Android emulator's own preflight
# check reads /etc/group and gives wrong negatives in rootless containers
# even when KVM access physically works). When KVM is reachable we force
# `-accel on` to bypass the preflight; otherwise fall back to TCG software
# emulation (`-accel off`) so the container at least boots (slowly) on
# KVM-less hosts (e.g. CI runners). NB: the emulator's `-accel` flag only
# accepts on|off|auto — `-accel kvm` is rejected ("Invalid '-accel kvm'
# parameter, valid values are: on off auto") and the emulator exits
# immediately, which supervisord reports as "FATAL Exited too quickly".
if python3 -c "import os,fcntl; fd=os.open('/dev/kvm', os.O_RDWR); fcntl.ioctl(fd, 0xae00)" 2>/dev/null; then
  ACCEL_FLAGS="-accel on"
  echo "[start-emulator] KVM reachable; using -accel on" >&2
else
  ACCEL_FLAGS="-accel off"
  echo "[start-emulator] KVM not reachable; falling back to -accel off (slow)" >&2
fi

# -no-window: run headless (no Qt UI window). With xcb-util-cursor installed
# (via android-sdk layer), the Qt xcb plugin loads cleanly under Xwayland
# and a window WOULD appear, but the headless flag keeps the emulator
# alive even if Qt fails (defensive — R10 ADB/boot checks work either way).
# Remove -no-window if you want the emulator window to appear inside the
# Selkies streamed desktop.
echo "[start-emulator] Launching emulator @${EMULATOR_NAME}..." >&2
exec "${ANDROID_HOME}/emulator/emulator" "@${EMULATOR_NAME}" \
  -no-window \
  -no-snapshot-save \
  -no-snapshot-load \
  -gpu swiftshader_indirect \
  -no-boot-anim \
  -no-audio \
  -memory "${EMULATOR_MEMORY}" \
  -cores "${EMULATOR_CORES}" \
  $ACCEL_FLAGS \
  -ports 5554,5555
