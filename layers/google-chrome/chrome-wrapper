#!/bin/sh
SOCKET="${XDG_RUNTIME_DIR:-/tmp}/${WAYLAND_DISPLAY:-wayland-1}"
TIMEOUT=30
ELAPSED=0
while [ ! -e "$SOCKET" ] && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done
if [ ! -e "$SOCKET" ]; then
    echo "chrome-wrapper: Wayland socket $SOCKET not found after ${TIMEOUT}s" >&2
    exit 1
fi
exec google-chrome-stable $CHROME_FLAGS --remote-debugging-port=9222 --remote-debugging-address=0.0.0.0 --user-data-dir="$HOME/.chrome-debug"
