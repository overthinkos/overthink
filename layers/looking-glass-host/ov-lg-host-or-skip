#!/bin/bash
# ov-lg-host-or-skip — graceful-skip wrapper for looking-glass-host.
#
# ov sessions are Wayland-only. looking-glass-host's only compiled capture
# backends are XCB (needs an X11 root window — never present on ov) and
# PipeWire (needs a headless KDE ScreenCast-portal grant, unavailable
# unattended). So looking-glass-host cannot capture on ov at all, and a
# `restart: always` unit crash-loops into a failed unit (SIGABRT →
# start-limit-hit). Skip cleanly (exit 0) so the unit records a clean
# "skipped" state instead of crash-looping. The host binary + kvmfr +
# IVSHMEM wiring stay in place for the operator-side looking-glass-client and
# for a future headless-Wayland capture backend.
# See CHANGELOG (Looking Glass headless-Wayland capture).
echo "ov-lg-host-or-skip: ov is Wayland-only and looking-glass-host has no headless Wayland capture backend (XCB needs X11; PipeWire needs a screencast-portal grant) — skipping Looking Glass capture cleanly."
exit 0
