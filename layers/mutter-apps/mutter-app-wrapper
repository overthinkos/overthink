#!/bin/sh
# Wait for Mutter's Wayland display before launching an app
SOCKET="${XDG_RUNTIME_DIR:-/tmp}/${WAYLAND_DISPLAY:-wayland-0}"
TIMEOUT=30
ELAPSED=0
while [ ! -e "$SOCKET" ] && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done
sleep 2  # Extra delay to let Mutter finish initialization
exec "$@"
