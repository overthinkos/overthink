#!/bin/sh
SOCKET="${XDG_RUNTIME_DIR:-/tmp}/${WAYLAND_DISPLAY:-wayland-0}"
TIMEOUT=30
ELAPSED=0
while [ ! -e "$SOCKET" ] && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done
if [ ! -e "$SOCKET" ]; then
    echo "noctalia-wrapper: Wayland socket $SOCKET not found after ${TIMEOUT}s" >&2
    exit 1
fi
# Discover sway IPC socket for swaymsg commands
SWAYSOCK=$(ls ${XDG_RUNTIME_DIR:-/tmp}/sway-ipc.*.sock 2>/dev/null | head -1)
[ -n "$SWAYSOCK" ] && export SWAYSOCK

exec qs -c noctalia-shell --no-duplicate
