#!/bin/sh
# selkies-wrapper: Start Selkies streaming server.
# Pixelflux creates its own Wayland compositor (wayland-1).
# labwc connects to it as a nested compositor.

# Add NVIDIA NVRTC library path (installed by pip nvidia-cuda-nvrtc)
NVRTC_PATH="$HOME/.pixi/envs/default/lib/python3.13/site-packages/nvidia/cu13/lib"
if [ -d "$NVRTC_PATH" ]; then
    export LD_LIBRARY_PATH="${NVRTC_PATH}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi

# GPU detection for NVENC hardware encoding
if command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi >/dev/null 2>&1; then
    echo "selkies-wrapper: NVIDIA GPU detected, DRINODE=${DRINODE:-not set}"
fi

# Default framerate 60fps. Don't set SELKIES_ENCODER — let pixelflux
# auto-detect GPU (NVENC/VAAPI) and fall back to CPU if unavailable.
export SELKIES_FRAMERATE="${SELKIES_FRAMERATE:-60}"

# Wait for PipeWire/PulseAudio to be ready, then setup null sinks for audio capture
TIMEOUT=15
ELAPSED=0
while ! pactl info >/dev/null 2>&1 && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done

if pactl info >/dev/null 2>&1; then
    if [ ! -f /dev/shm/selkies-audio.lock ]; then
        pactl load-module module-null-sink sink_name=output sink_properties=device.description="output" 2>/dev/null || true
        pactl load-module module-null-sink sink_name=input sink_properties=device.description="input" 2>/dev/null || true
        pactl set-default-sink output 2>/dev/null || true
        touch /dev/shm/selkies-audio.lock
        echo "selkies-wrapper: PulseAudio null sinks configured"
    fi
else
    echo "selkies-wrapper: WARNING: PulseAudio not available after ${TIMEOUT}s"
fi

# Start the in-process capture server alongside selkies.
# The capture server shares pixelflux's global WaylandBackend so it can
# capture the full composited desktop (labwc renders into pixelflux's
# compositor). Standalone scripts can't do this — they create their own
# empty compositor. See selkies-capture-server for protocol details.
CAPTURE_SERVER="$HOME/.local/bin/selkies-capture-server"
# Direct exec so selkies-capture-server's own shebang resolves the
# interpreter (pinned to the pixi env's python). `python3 "$SCRIPT"`
# would override the shebang and route through whatever /usr/bin/python3
# happens to point at — Fedora 43 made that python3.14, but the pixi
# env (with websockets, pixelflux, pcmflux) is on 3.13.
exec "$CAPTURE_SERVER" --addr="0.0.0.0" --mode="websockets"
