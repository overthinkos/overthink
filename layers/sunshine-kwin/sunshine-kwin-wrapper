#!/bin/sh
# sunshine-kwin-wrapper: Start Sunshine with XDG Desktop Portal capture.
# Input injection via libei (EIS protocol through portal RemoteDesktop).
# No fake-udev, no /dev/uinput, no special capabilities needed.

SOCKET="${XDG_RUNTIME_DIR:-/tmp}/${WAYLAND_DISPLAY:-wayland-0}"
TIMEOUT=30
ELAPSED=0

# Phase 1: Wait for Wayland display socket
while [ ! -e "$SOCKET" ] && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done
if [ ! -e "$SOCKET" ]; then
    echo "sunshine-kwin-wrapper: Wayland socket $SOCKET not found after ${TIMEOUT}s" >&2
    exit 1
fi

# Phase 2: Wait for D-Bus session bus
ELAPSED=0
while [ ! -e "/tmp/dbus-session" ] && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done
if [ ! -e "/tmp/dbus-session" ]; then
    echo "sunshine-kwin-wrapper: D-Bus session socket not found after ${TIMEOUT}s" >&2
    exit 1
fi

# Phase 3: Export environment to D-Bus for portal activation.
# KWin headless doesn't automatically export these to the D-Bus activation
# environment, so portal backends won't find the compositor without this.
dbus-update-activation-environment \
    WAYLAND_DISPLAY XDG_RUNTIME_DIR XDG_CURRENT_DESKTOP DISPLAY 2>/dev/null || true

# Wait for portal daemon to D-Bus activate
sleep 2

# Generate default config if none exists
SUNSHINE_CFG="$HOME/.config/sunshine/sunshine.conf"
if [ ! -f "$SUNSHINE_CFG" ]; then
    mkdir -p "$HOME/.config/sunshine"
    cat > "$SUNSHINE_CFG" << 'CONF'
# Sunshine config for KWin portal capture (auto-generated by sunshine-kwin-wrapper)
capture = portal
encoder = nvenc
audio_sink = auto
origin_web_ui_allowed = lan
CONF
fi

exec sunshine "$SUNSHINE_CFG"
