#!/usr/bin/python3
"""Bridge Sunshine uinput events to Mutter via native RemoteDesktop D-Bus API.

Reads evdev events from Sunshine's virtual input devices (/dev/input/eventN)
and forwards them to Mutter's org.gnome.Mutter.RemoteDesktop session as
NotifyKeyboardKeycode, NotifyPointerMotionRelative, NotifyPointerButton,
and NotifyPointerAxisDiscrete calls.

No fake-udev, no LIBSEAT_BACKEND, no NET_ADMIN needed. Pure D-Bus.
"""
import os
import sys
import struct
import select
import time
import glob

try:
    import gi
    gi.require_version("Gio", "2.0")
    from gi.repository import Gio, GLib
except (ImportError, ValueError) as e:
    print(f"mutter-input-bridge: GLib not available: {e}", file=sys.stderr)
    sys.exit(1)

# evdev constants
EV_SYN, EV_KEY, EV_REL, EV_ABS = 0, 1, 2, 3
REL_X, REL_Y, REL_WHEEL, REL_HWHEEL = 0, 1, 8, 6
ABS_X, ABS_Y = 0, 1
BTN_MOUSE = 0x110  # BTN_LEFT=272, BTN_RIGHT=273, BTN_MIDDLE=274

# evdev input_event struct: timeval(16 bytes) + type(2) + code(2) + value(4) = 24 bytes
EVENT_SIZE = 24
EVENT_FMT = "llHHi"

# Sunshine virtual device identifiers (vendor=0xBEEF, product=0xDEAD)
SUNSHINE_VENDOR = 0xBEEF
SUNSHINE_PRODUCT = 0xDEAD


def find_sunshine_devices():
    """Find Sunshine virtual input devices by checking vendor/product IDs."""
    devices = []
    for path in sorted(glob.glob("/dev/input/event*")):
        try:
            # EVIOCGID ioctl to get device ID
            import fcntl
            import array
            fd = os.open(path, os.O_RDONLY | os.O_NONBLOCK)
            buf = array.array("H", [0, 0, 0, 0])
            fcntl.ioctl(fd, 0x80084502, buf)  # EVIOCGID
            bustype, vendor, product, version = buf
            if vendor == SUNSHINE_VENDOR and product == SUNSHINE_PRODUCT:
                devices.append((path, fd))
            else:
                os.close(fd)
        except (OSError, IOError):
            continue
    return devices


def find_any_new_devices(existing_fds):
    """Find any new input devices that appeared after startup."""
    existing_paths = {info[0] for info in existing_fds}
    new_devices = []
    for path in sorted(glob.glob("/dev/input/event*")):
        if path not in existing_paths:
            try:
                fd = os.open(path, os.O_RDONLY | os.O_NONBLOCK)
                new_devices.append((path, fd))
            except (OSError, IOError):
                continue
    return new_devices


def create_mutter_session(bus):
    """Create and start a Mutter RemoteDesktop session."""
    result = bus.call_sync(
        "org.gnome.Mutter.RemoteDesktop",
        "/org/gnome/Mutter/RemoteDesktop",
        "org.gnome.Mutter.RemoteDesktop",
        "CreateSession",
        None, GLib.VariantType("(o)"),
        Gio.DBusCallFlags.NONE, -1, None)
    session_path = result.get_child_value(0).get_string()

    bus.call_sync(
        "org.gnome.Mutter.RemoteDesktop", session_path,
        "org.gnome.Mutter.RemoteDesktop.Session", "Start",
        None, None, Gio.DBusCallFlags.NONE, -1, None)

    return session_path


def forward_events(bus, session_path, devices):
    """Read evdev events and forward to Mutter RemoteDesktop session."""
    fds = {fd: path for path, fd in devices}
    poll = select.poll()
    for fd in fds:
        poll.register(fd, select.POLLIN)

    # Accumulated relative motion (batch per SYN_REPORT)
    rel_x, rel_y = 0.0, 0.0

    # Mouse sensitivity scale factor — Sunshine's uinput generates raw pixel
    # deltas that are too large for Mutter's virtual pointer. Scale down to
    # match typical desktop mouse sensitivity.
    MOUSE_SCALE = 0.4

    print(f"mutter-input-bridge: forwarding {len(devices)} devices")

    while True:
        try:
            events = poll.poll(1000)
        except KeyboardInterrupt:
            break

        for fd, mask in events:
            if not (mask & select.POLLIN):
                continue
            try:
                data = os.read(fd, EVENT_SIZE * 64)
            except OSError:
                continue

            offset = 0
            while offset + EVENT_SIZE <= len(data):
                _sec, _usec, ev_type, ev_code, ev_value = struct.unpack_from(
                    EVENT_FMT, data, offset)
                offset += EVENT_SIZE

                if ev_type == EV_REL:
                    if ev_code == REL_X:
                        rel_x += ev_value
                    elif ev_code == REL_Y:
                        rel_y += ev_value
                    elif ev_code == REL_WHEEL:
                        try:
                            bus.call_sync(
                                "org.gnome.Mutter.RemoteDesktop", session_path,
                                "org.gnome.Mutter.RemoteDesktop.Session",
                                "NotifyPointerAxisDiscrete",
                                GLib.Variant("(ui)", (0, -ev_value)),
                                None, Gio.DBusCallFlags.NONE, -1, None)
                        except Exception:
                            pass
                    elif ev_code == REL_HWHEEL:
                        try:
                            bus.call_sync(
                                "org.gnome.Mutter.RemoteDesktop", session_path,
                                "org.gnome.Mutter.RemoteDesktop.Session",
                                "NotifyPointerAxisDiscrete",
                                GLib.Variant("(ui)", (1, ev_value)),
                                None, Gio.DBusCallFlags.NONE, -1, None)
                        except Exception:
                            pass

                elif ev_type == EV_KEY:
                    pressed = ev_value > 0  # 1=press, 0=release, 2=repeat
                    if 0x110 <= ev_code <= 0x117:  # BTN_LEFT..BTN_TASK (mouse buttons)
                        try:
                            bus.call_sync(
                                "org.gnome.Mutter.RemoteDesktop", session_path,
                                "org.gnome.Mutter.RemoteDesktop.Session",
                                "NotifyPointerButton",
                                GLib.Variant("(ib)", (ev_code, pressed)),
                                None, Gio.DBusCallFlags.NONE, -1, None)
                        except Exception:
                            pass
                    else:  # Keyboard key
                        try:
                            bus.call_sync(
                                "org.gnome.Mutter.RemoteDesktop", session_path,
                                "org.gnome.Mutter.RemoteDesktop.Session",
                                "NotifyKeyboardKeycode",
                                GLib.Variant("(ub)", (ev_code, pressed)),
                                None, Gio.DBusCallFlags.NONE, -1, None)
                        except Exception:
                            pass

                elif ev_type == EV_SYN and ev_code == 0:  # SYN_REPORT
                    if rel_x != 0.0 or rel_y != 0.0:
                        try:
                            bus.call_sync(
                                "org.gnome.Mutter.RemoteDesktop", session_path,
                                "org.gnome.Mutter.RemoteDesktop.Session",
                                "NotifyPointerMotionRelative",
                                GLib.Variant("(dd)", (rel_x * MOUSE_SCALE, rel_y * MOUSE_SCALE)),
                                None, Gio.DBusCallFlags.NONE, -1, None)
                        except Exception:
                            pass
                        rel_x, rel_y = 0.0, 0.0


def main():
    # Wait for Sunshine to create its virtual devices
    print("mutter-input-bridge: waiting for Sunshine virtual input devices...")
    timeout = 120
    elapsed = 0
    devices = []

    while elapsed < timeout:
        devices = find_sunshine_devices()
        if devices:
            break
        # Also try any new devices (Sunshine may not use vendor 0xBEEF in all versions)
        time.sleep(2)
        elapsed += 2

    if not devices:
        # Fallback: try ALL new event devices that appeared recently
        print("mutter-input-bridge: no Sunshine vendor devices found, checking recent devices...")
        time.sleep(5)
        devices = find_any_new_devices([])
        if not devices:
            print("mutter-input-bridge: no input devices found", file=sys.stderr)
            sys.exit(1)

    for path, fd in devices:
        print(f"mutter-input-bridge: found device {path}")

    # Create Mutter RemoteDesktop session
    bus = Gio.bus_get_sync(Gio.BusType.SESSION)
    try:
        session_path = create_mutter_session(bus)
        print(f"mutter-input-bridge: RemoteDesktop session {session_path}")
    except Exception as e:
        print(f"mutter-input-bridge: failed to create session: {e}", file=sys.stderr)
        sys.exit(1)

    # Forward events
    try:
        forward_events(bus, session_path, devices)
    except KeyboardInterrupt:
        pass
    finally:
        try:
            bus.call_sync(
                "org.gnome.Mutter.RemoteDesktop", session_path,
                "org.gnome.Mutter.RemoteDesktop.Session", "Stop",
                None, None, Gio.DBusCallFlags.NONE, -1, None)
        except Exception:
            pass
        for _, fd in devices:
            os.close(fd)


if __name__ == "__main__":
    main()
