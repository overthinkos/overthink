#!/bin/sh
# sunshine-niri-wrapper: Simplified Sunshine startup for Niri compositor.
# No sway IPC socket wait phase — just wait for the Wayland display socket.

SOCKET="${XDG_RUNTIME_DIR:-/tmp}/${WAYLAND_DISPLAY:-wayland-0}"
TIMEOUT=30
ELAPSED=0

# Wait for Wayland display socket (single phase — no sway IPC socket needed)
while [ ! -e "$SOCKET" ] && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done
if [ ! -e "$SOCKET" ]; then
    echo "sunshine-niri-wrapper: Wayland socket $SOCKET not found after ${TIMEOUT}s" >&2
    exit 1
fi

# Generate default config if none exists.
# Niri headless uses wlr-screencopy for screen capture (same protocol as Sway).
# Auto-detect encoder: nvenc (NVIDIA), vaapi (AMD/Intel), software (fallback).
SUNSHINE_CFG="$HOME/.config/sunshine/sunshine.conf"
if [ ! -f "$SUNSHINE_CFG" ]; then
    mkdir -p "$HOME/.config/sunshine"
    cat > "$SUNSHINE_CFG" << 'CONF'
# Sunshine config for Niri headless (auto-generated by sunshine-niri-wrapper)
# wlroots capture works via wlr-screencopy protocol on niri virtual outputs.
capture = wlroots
audio_sink = auto
origin_web_ui_allowed = lan
CONF
fi

exec sunshine "$SUNSHINE_CFG"
