#!/bin/sh
# sunshine-x11-wrapper: Start Sunshine with X11 capture.
# No fake-udev, no Wayland sockets, no compositor input hacks.
# Input injection via XTest (native X11), screen capture via X11.

TIMEOUT=30
ELAPSED=0
while ! xdpyinfo -display :0 >/dev/null 2>&1 && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done
if ! xdpyinfo -display :0 >/dev/null 2>&1; then
    echo "sunshine-x11-wrapper: X display :0 not ready after ${TIMEOUT}s" >&2
    exit 1
fi

# Generate default config if none exists
SUNSHINE_CFG="$HOME/.config/sunshine/sunshine.conf"
if [ ! -f "$SUNSHINE_CFG" ]; then
    mkdir -p "$HOME/.config/sunshine"
    cat > "$SUNSHINE_CFG" << 'CONF'
# Sunshine config for X11 (auto-generated by sunshine-x11-wrapper)
capture = x11
audio_sink = auto
origin_web_ui_allowed = lan
CONF
fi

exec sunshine "$SUNSHINE_CFG"
