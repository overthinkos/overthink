#!/bin/sh
SOCKET="${XDG_RUNTIME_DIR:-/tmp}/${WAYLAND_DISPLAY:-wayland-0}"
TIMEOUT=30
ELAPSED=0

# Phase 1: Wait for Wayland display socket
while [ ! -e "$SOCKET" ] && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done
if [ ! -e "$SOCKET" ]; then
    echo "sunshine-wrapper: Wayland socket $SOCKET not found after ${TIMEOUT}s" >&2
    exit 1
fi

# Phase 2: Wait for sway IPC socket (resolution set by sway-wrapper)
ELAPSED=0
while [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    SWAYSOCK=$(ls -t /tmp/sway-ipc.*.sock 2>/dev/null | head -1)
    [ -n "$SWAYSOCK" ] && break
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done
sleep 2

# Generate default config if none exists
SUNSHINE_CFG="$HOME/.config/sunshine/sunshine.conf"
if [ ! -f "$SUNSHINE_CFG" ]; then
    mkdir -p "$HOME/.config/sunshine"
    cat > "$SUNSHINE_CFG" << 'CONF'
# Sunshine config (auto-generated by sunshine-wrapper)
capture = wlroots
encoder = nvenc
audio_sink = auto
origin_web_ui_allowed = lan
CONF
fi

exec sunshine "$SUNSHINE_CFG"
