#!/bin/sh
# wolf-wrapper: GPU detection and startup sequencing for Wolf

# --- GPU detection ---
if command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi >/dev/null 2>&1; then
    echo "wolf-wrapper: NVIDIA GPU detected"
    export WOLF_RENDER_NODE="${WOLF_RENDER_NODE:-/dev/dri/renderD128}"
    export GST_GL_API="${GST_GL_API:-gles2}"
    export GST_GL_WINDOW="${GST_GL_WINDOW:-surfaceless}"
elif ls /dev/dri/renderD* >/dev/null 2>&1; then
    RENDER_NODE=$(ls /dev/dri/renderD* 2>/dev/null | head -1)
    echo "wolf-wrapper: GPU detected at $RENDER_NODE (VAAPI)"
    export WOLF_RENDER_NODE="${WOLF_RENDER_NODE:-$RENDER_NODE}"
    export GST_GL_API="${GST_GL_API:-gles2}"
    export GST_GL_WINDOW="${GST_GL_WINDOW:-surfaceless}"
else
    echo "wolf-wrapper: WARNING: No GPU detected, software encoding will be used" >&2
fi

# --- Wait for Docker/Podman socket ---
DOCKER_SOCKET="${DOCKER_HOST:-/var/run/docker.sock}"
DOCKER_SOCKET="${DOCKER_SOCKET#unix://}"
TIMEOUT=30
ELAPSED=0
while [ ! -S "$DOCKER_SOCKET" ] && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
done
if [ ! -S "$DOCKER_SOCKET" ]; then
    echo "wolf-wrapper: WARNING: Docker socket $DOCKER_SOCKET not found after ${TIMEOUT}s" >&2
    echo "wolf-wrapper: Wolf will start but per-app container spawning may not work" >&2
else
    echo "wolf-wrapper: Docker socket ready at $DOCKER_SOCKET"
fi

# --- Set up runtime and udev directories ---
mkdir -p "${XDG_RUNTIME_DIR:-/run/wolf}"
mkdir -p /run/udev/data
touch /run/udev/control

# --- Ensure config directory is writable ---
CFG_DIR="$(dirname "${WOLF_CFG_FILE:-/home/user/.config/wolf/config.toml}")"
mkdir -p "$CFG_DIR"

# --- Generate default config if none exists ---
CFG="${WOLF_CFG_FILE:-/etc/wolf/cfg/config.toml}"
if [ ! -f "$CFG" ]; then
    cat > "$CFG" << 'CONF'
# Wolf config (auto-generated by wolf-wrapper)
hostname = "Wolf"
support_hevc = true

[gstreamer]
# Encoding pipeline — Wolf auto-detects available encoders.
# Override here if needed: "nvenc", "vaapi", "qsv", "software"
CONF
    echo "wolf-wrapper: Generated default config at $CFG"
fi

exec wolf
